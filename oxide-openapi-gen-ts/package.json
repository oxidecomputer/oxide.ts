{
  "name": "@oxide/openapi-gen-ts",
  "version": "0.15.1",
  "description": "OpenAPI client generator used to generate Oxide TypeScript SDK",
  "keywords": [
    "OpenAPI client generator",
    "oxide",
    "oxide sdk",
    "oxide.ts"
  ],
  "homepage": "https://github.com/oxidecomputer/oxide.ts#readme",
  "license": "MPL-2.0",
  "author": "Oxide Computer Company",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxidecomputer/oxide.ts.git"
  },
  "bin": {
    "openapi-gen-ts": "dist/index.cjs"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsdown && mkdir -p dist/static/ && cp src/client/static/util.ts dist/static/ && cp src/client/static/http-client.ts dist/static/",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "prepublishOnly": "npm run build",
    "pretest": "../tools/gen.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "tsc": "tsc"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.0.3",
    "@commander-js/extra-typings": "^14.0.0",
    "ts-pattern": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "openapi-types": "^12.1.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsafe": "^1.6.6",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "fixedExtension": false,
    "format": [
      "cjs",
      "esm"
    ],
    "shims": true
  },
  "engines": {
    "node": ">=24"
  }
}
