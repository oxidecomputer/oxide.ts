{
  "name": "@oxide/openapi-gen-ts",
  "version": "0.15.0",
  "description": "OpenAPI client generator used to generate Oxide TypeScript SDK",
  "keywords": [
    "oxide",
    "oxide.ts",
    "oxide sdk",
    "OpenAPI client generator"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "bin": {
    "openapi-gen-ts": "dist/index.cjs"
  },
  "tsdown": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "fixedExtension": false,
    "shims": true
  },
  "scripts": {
    "build": "tsdown && mkdir -p dist/static/ && cp src/client/static/util.ts dist/static/ && cp src/client/static/http-client.ts dist/static/",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepublishOnly": "npm run build",
    "pretest": "../tools/gen.sh",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "tsc": "tsc"
  },
  "author": "Oxide Computer Company",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oxidecomputer/oxide.ts.git"
  },
  "homepage": "https://github.com/oxidecomputer/oxide.ts#readme",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.0.3",
    "@commander-js/extra-typings": "^14.0.0",
    "prettier": "2.7.1",
    "ts-pattern": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/prettier": "^2.7.3",
    "openapi-types": "^12.1.3",
    "oxlint": "^1.70.0",
    "tsafe": "^1.6.6",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
